# TieZ Clipboard - Environment Structure Example
# Copy this to .env and fill in your values for local builds.
# In GitHub Actions, use repository secrets / variables with the same names.

# AI
VITE_AI_DEFAULT_API_KEY=

# Update service
TIEZ_UPDATE_ENDPOINT=https://your-api.com/api/v1/latest-version
VITE_TIEZ_UPDATE_ENDPOINT=https://your-api.com/api/v1/latest-version
TIEZ_UPDATER_PUBLIC_KEY=

# Announcement service
TIEZ_ANNOUNCEMENT_PING_URL=https://your-api.com/api/v1/ping
VITE_TIEZ_ANNOUNCEMENT_PING_URL=https://your-api.com/api/v1/ping
