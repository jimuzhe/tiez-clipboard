{
  "name": "tiez-app",
  "private": true,
  "version": "0.3.3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:mqtt:stress": "node tests/mqtt/mqtt_stress_publish.js",
    "test:file:stress": "node tests/file_transfer/file_transfer_stress.js",
    "build": "tsc && vite build",
    "build:signed": "dotenv -- tauri build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "build:portable": "tauri build --no-bundle --features portable && powershell -NoProfile -Command \"$ErrorActionPreference='Stop'; $out='artifacts/portable'; New-Item -ItemType Directory -Force -Path $out | Out-Null; New-Item -ItemType Directory -Force -Path (Join-Path $out 'data') | Out-Null; Get-ChildItem 'src-tauri/target/release' -Filter *.exe | ForEach-Object { Copy-Item $_.FullName -Destination (Join-Path $out 'tiez-app.exe') -Force }; Set-Content -Path (Join-Path $out '说明.txt') -Value '本软件完全免费，严禁未经许可的第三方倒卖。`r`n`r`n便携版的更新请不要使用设置项内的检查更新，请到官网 https://tiez.name666.top 下载最新版。`r`n后将 tiez-app.exe 复制到原来的文件夹内进行替换即可。' -Encoding UTF8; Compress-Archive -Path (Join-Path $out '*') -DestinationPath (Join-Path $out 'tiez-portable.zip') -Force\""
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@types/prismjs": "^1.26.5",
    "@types/react-window": "^1.8.8",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.25.0",
    "franc-min": "^6.2.0",
    "lucide-react": "^0.562.0",
    "prismjs": "^1.30.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-select": "^5.10.2",
    "react-virtuoso": "^4.18.1",
    "react-window": "^1.8.10",
    "tailwind-merge": "^3.4.0",
    "use-resize-observer": "^9.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@tauri-apps/cli": "^2.10.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/react-select": "^5.0.0",
    "@vitejs/plugin-react": "^4.6.0",
    "aedes": "^0.50.0",
    "express": "^4.18.2",
    "form-data": "^4.0.0",
    "mqtt": "^4.3.7",
    "multer": "^1.4.4",
    "node-fetch": "^2.6.7",
    "playwright": "^1.40.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "4.0.18"
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom"
  }
}
